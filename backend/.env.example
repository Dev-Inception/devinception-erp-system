# Server
# Note: avoid 5000 on macOS — it's used by Control Center / AirPlay Receiver.
PORT=5050
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/point-of-sale

# JWT
JWT_ACCESS_SECRET=change_this_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# Password reset token lifetime (minutes)
RESET_TOKEN_EXPIRES_MIN=15

# Mail (SMTP) — e.g. Mailtrap / Gmail / SES
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
MAIL_FROM="Point of Sale <no-reply@devinception.com>"

# Bootstrap super admin (used by seed script)
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@devinception.com
SUPER_ADMIN_PASSWORD=ChangeMe123!
