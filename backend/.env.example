# ─── Database (MongoDB) ─────────────────────────────────────
# MongoDB connection string (Atlas SRV or local). Example:
#   mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/devinception_erp
MONGODB_URI="mongodb://localhost:27017/devinception_erp"

# ─── Backend / API ──────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173

# ─── Auth (JWT) ─────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── File storage ───────────────────────────────────────────
STORAGE_DIR=./storage
